{
  "name": "@modo/api-tools",
  "version": "1.0.0",
  "description": "Librería de herramientas para APIs con interceptors personalizados",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "example": "ts-node examples/main.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:toon:manual": "ts-node examples/test-toon.ts",
    "test:dual:manual": "ts-node examples/test-dual-format.ts",
    "lint": "eslint \"lib/**/*.ts\"",
    "lint:fix": "eslint \"lib/**/*.ts\" --fix",
    "format": "prettier --write \"lib/**/*.ts\" \"examples/**/*.ts\"",
    "format:check": "prettier --check \"lib/**/*.ts\" \"examples/**/*.ts\"",
    "prepare": "husky"
  },
  "keywords": [
    "api",
    "interceptor",
    "llm",
    "nestjs",
    "openapi",
    "swagger",
    "token-optimization",
    "toon",
    "toon-format",
    "tools",
    "typescript"
  ],
  "author": "Modo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/modo/modo-llms-api-tools.git"
  },
  "bugs": {
    "url": "https://github.com/modo/modo-llms-api-tools/issues"
  },
  "homepage": "https://github.com/modo/modo-llms-api-tools#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/testing": "^10.4.20",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.0.0",
    "jest": "^30.2.0",
    "prettier": "^3.6.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.46.3"
  },
  "dependencies": {
    "@toon-format/toon": "^0.7.3"
  }
}
